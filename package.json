{
  "name": "hotel-management-system",
  "version": "1.0.0",
  "description": "Professional Hotel and Convention Hall Management System",
  "author": "The Retinue Team",
  "private": true,
  "main": "electron-main.js",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:reset-sql": "node prisma/reset-db.js",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "create-users": "tsx scripts/create-default-users.ts",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@react-pdf/renderer": "^3.4.3",
    "@tanstack/react-query": "^5.17.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.6",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "next": "^14.2.18",
    "next-auth": "^4.24.5",
    "nodemailer": "^7.0.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.2",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^4.12.0",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/moment": "^2.11.29",
    "@types/node": "^20.19.30",
    "@types/prop-types": "^15.7.12",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.32",
    "prisma": "^5.7.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "wait-on": "^9.0.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "build": {
    "appId": "com.hotel.management",
    "productName": "Retinue Hotel Management",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "splash.html",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo.png"
    }
  }
}
